function deepMerge(array $original, array $incoming): array
{
    foreach ($incoming as $key => $value) {
        if (
            array_key_exists($key, $original) &&
            is_array($original[$key]) &&
            is_array($value)
        ) {
            $original[$key] = deepMerge($original[$key], $value);
        } else {
            $original[$key] = $value;
        }
    }

    return $original;
}

$languages = DB::table('languages')->get()->keyBy('code');

foreach ($translationsByCode as $code => $newItems) {
    $language = $languages->get($code);

    if (!$language) {
        echo "Language not found for code: {$code}\n";
        continue;
    }

    $row = DB::table('language_files')
        ->where('language_id', $language->id)
        ->where('scope', $scope)
        ->first();

    if (!$row) {
        DB::table('language_files')->insert([
            'language_id' => $language->id,
            'title' => $language->title ?? $code,
            'scope' => $scope,
            'json_data' => json_encode($newItems, JSON_UNESCAPED_UNICODE),
            'created_at' => now(),
            'updated_at' => now(),
        ]);

        echo "Created translations for {$code}\n";
        continue;
    }

    $currentJson = [];
    if (!empty($row->json_data)) {
        $decoded = json_decode($row->json_data, true);
        if (is_array($decoded)) {
            $currentJson = $decoded;
        }
    }

    $merged = deepMerge($currentJson, $newItems);

    DB::table('language_files')
        ->where('id', $row->id)
        ->update([
            'json_data' => json_encode($merged, JSON_UNESCAPED_UNICODE),
            'updated_at' => now(),
        ]);

    echo "Updated translations for {$code}\n";
}

echo "Done.\n";